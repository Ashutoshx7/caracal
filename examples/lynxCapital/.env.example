# Required user values
OPENAI_API_KEY=sk-...

# Caracal runtime values from manual setup
CARACAL_ZONE_ID=<placeholder-zone-id>

CARACAL_APPLICATION_ID=<placeholder-application-id>

CARACAL_APP_CLIENT_SECRET=<placeholder-application-secret>

# Control automation values from Automate Setup
CONTROL_CLIENT_ID="<placeholder-control-client-id>"

CONTROL_CLIENT_SECRET="<placeholder-control-client-secret>"

# Local demo defaults
LYNX_PROVIDER_HEALTH_URL=http://127.0.0.1:9400/healthz

CARACAL_RESOURCES=halcyon-bank=http://127.0.0.1:9400,meridian-pay=http://127.0.0.1:9401,cordoba-fx=http://127.0.0.1:9402,ironbark-erp=http://127.0.0.1:9403,tallyhall-books=http://127.0.0.1:9404,slate-ledger=http://127.0.0.1:9405,inkwell-ocr=http://127.0.0.1:9406,aegis-screening=http://127.0.0.1:9407,verafin-monitor=http://127.0.0.1:9408,beacon-crm=http://127.0.0.1:9410,atlas-vendor=http://127.0.0.1:9411,keystone-treasury=http://127.0.0.1:9412,sabre-tax=http://127.0.0.1:9413,quetzal-payouts=http://127.0.0.1:9414,vela-notify=http://127.0.0.1:9415,relay-automation=http://127.0.0.1:9417,pulse-market=http://127.0.0.1:9418,junction-procure=http://127.0.0.1:9419

