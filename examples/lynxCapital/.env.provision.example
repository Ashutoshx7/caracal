# Lynx Capital — operator provisioning environment (scripts/provision.py)
#
# Copy to .env.provision, fill in, then source it before provisioning:
#   cp .env.provision.example .env.provision
#   $EDITOR .env.provision
#   . .env.provision
#   python scripts/provision.py
#
# These variables belong to the operator who provisions the zone, NOT to the running
# application. Keep them out of the workload .env. The scoped Control key is created once in
# Console (Control menu); Console returns a one-time client secret and the scopes the key may
# request. The key is zone-bound, application-only, and short-TTL. Never commit the secret.

# Scoped Control key issued by Console.
CONTROL_CLIENT_ID=<control-key-client-id>
CONTROL_CLIENT_SECRET=<one-time-control-key-secret>

# Optional: override the Control API surface. Defaults to http://127.0.0.1:8087.
# CONTROL_URL=http://127.0.0.1:8087

# Optional: override the STS token endpoint. Defaults to http://127.0.0.1:8080.
# STS_URL=http://127.0.0.1:8080

# Optional: override the Control resource audience. Defaults to caracal-control.
# CONTROL_AUDIENCE=caracal-control

# Optional: override the requested scopes (space or comma separated). When unset the script
# requests the provider, resource, and policy read/write/delete scopes it needs. The key
# still only receives scopes Console allowed it.
# CONTROL_SCOPES="control:resource:write control:policy:write control:policy-set:write"

# Optional: requested token TTL in seconds (capped by the key's max TTL).
# CONTROL_TTL_SECONDS=300

# The upstream URL each domain resource is registered with at provisioning time. The
# identifiers and scopes live in config/tenancy.yaml; these point each one at its upstream
# for this environment.
LYNX_RESOURCE_PORTFOLIO_URL=http://127.0.0.1:9500
LYNX_RESOURCE_RESEARCH_URL=http://127.0.0.1:9501
LYNX_RESOURCE_COMPLIANCE_URL=http://127.0.0.1:9502
