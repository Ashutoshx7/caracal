{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.caracal.run/schemas/caracal-policy-result-2026-05-20.schema.json",
  "title": "Caracal OPA Policy Result",
  "description": "The result object returned by data.caracal.authz.result.",
  "type": "object",
  "required": ["decision", "evaluation_status", "determining_policies", "diagnostics"],
  "properties": {
    "decision": {
      "enum": ["allow", "deny"]
    },
    "evaluation_status": {
      "enum": ["complete", "partial", "error"]
    },
    "determining_policies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
