# Caracal, a product of Garudex Labs
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The auth service loads it automatically on `pnpm dev` / `pnpm start`.

# --- Core (optional; sensible localhost defaults already apply) ---
# CARACAL_AUTH_PORT=3002
# CARACAL_WEB_ORIGIN=http://localhost:3001
# Generate a strong secret for anything beyond local dev:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BETTER_AUTH_SECRET=change-me

# --- Google sign-in ---
# Google Cloud Console -> Credentials -> OAuth client ID (Web application)
# Authorized redirect URI: http://localhost:3002/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub sign-in ---
# GitHub -> Settings -> Developer settings -> OAuth Apps
# Authorization callback URL: http://localhost:3002/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
