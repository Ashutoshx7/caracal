{
  "schema_version": "2026-05-21",
  "name": "example-oauth-provider",
  "version": "1.0.0",
  "provider_kinds": ["oauth2", "oidc"],
  "config_schema": {
    "type": "object",
    "required": ["issuer", "token_endpoint"],
    "properties": {
      "issuer": {
        "type": "string",
        "format": "uri"
      },
      "token_endpoint": {
        "type": "string",
        "format": "uri"
      }
    }
  },
  "secret_schema": {
    "type": "object",
    "required": ["client_id", "client_secret"],
    "properties": {
      "client_id": {
        "type": "string"
      },
      "client_secret": {
        "type": "string"
      }
    }
  },
  "lifecycle": {
    "hooks": ["validate", "resolve", "refresh", "revoke"],
    "refresh_before_expiry_seconds": 60
  },
  "audit_metadata": {
    "fields": ["provider_id", "grant_id", "credential_subject"]
  },
  "execution": {
    "isolation": "external_service",
    "credential_exposure": "gateway_only"
  }
}
