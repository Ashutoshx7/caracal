{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.caracal.run/schemas/caracal-provider-credential-plugin-manifest-2026-05-21.schema.json",
  "title": "Caracal Provider Credential Plugin Manifest",
  "description": "Offline compatibility metadata for provider credential plugins.",
  "type": "object",
  "required": ["schema_version", "name", "version", "provider_kinds", "config_schema", "secret_schema", "lifecycle", "audit_metadata", "execution"],
  "properties": {
    "schema_version": {
      "const": "2026-05-21"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "provider_kinds": {
      "type": "array",
      "items": {
        "enum": ["oauth2", "oidc", "apikey", "workload"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "config_schema": {
      "type": "object",
      "additionalProperties": true
    },
    "secret_schema": {
      "type": "object",
      "additionalProperties": true
    },
    "lifecycle": {
      "type": "object",
      "required": ["hooks"],
      "properties": {
        "hooks": {
          "type": "array",
          "items": {
            "enum": ["validate", "resolve", "refresh", "revoke"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "refresh_before_expiry_seconds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "audit_metadata": {
      "type": "object",
      "required": ["fields"],
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": ["isolation", "credential_exposure"],
      "properties": {
        "isolation": {
          "enum": ["out_of_process", "sidecar", "external_service"]
        },
        "credential_exposure": {
          "const": "gateway_only"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
