{
  "schema_version": "2026-05-21",
  "name": "example-otel-audit-exporter",
  "version": "1.0.0",
  "event_schema_version": "2026-05-21",
  "destinations": ["otel_logs", "s3"],
  "delivery": {
    "mode": "stream",
    "retry": "at_least_once",
    "ordering": "ledger_order"
  },
  "redaction": {
    "forbidden_fields": ["authorization", "cookie", "provider_token", "request_body", "response_body"]
  },
  "replay": {
    "supported": true,
    "cursor": "ledger_sequence"
  }
}
