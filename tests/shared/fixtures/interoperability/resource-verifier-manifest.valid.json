{
  "schema_version": "2026-05-21",
  "name": "example-typescript-verifier",
  "version": "1.0.0",
  "languages": ["typescript"],
  "claim_profile": {
    "jwt_claim_schema_version": "2026-05-21",
    "requires_audience": true,
    "requires_target": true,
    "requires_scope": true,
    "requires_use_resource": true
  },
  "revocation": {
    "supported": true,
    "anchors": ["sid", "root_sid", "agent_session_id", "delegation_edge_id"]
  },
  "w3c_context": {
    "trace_context": true,
    "baggage": true
  },
  "audit": {
    "action_result_emitter": true
  },
  "conformance": {
    "fixtures": ["jwt-claims.resource.valid.json", "revocation-event.session.valid.json", "trace-context.headers.valid.json"]
  }
}
