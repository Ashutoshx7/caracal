 *
 * Two-state slider theme toggle, defaults to dark.
 */
---

<starlight-theme-toggle>
  <button type="button" class="theme-toggle" aria-label="Switch to light theme" aria-pressed="false">
    <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
        <path d="M5 12a1 1 0 0 0-1-1H3a1 1 0 0 0 0 2h1a1 1 0 0 0 1-1Zm.64 5-.71.71a1 1 0 0 0 0 1.41 1 1 0 0 0 1.41 0l.71-.71A1 1 0 0 0 5.64 17ZM12 5a1 1 0 0 0 1-1V3a1 1 0 0 0-2 0v1a1 1 0 0 0 1 1Zm5.66 2.34a1 1 0 0 0 .7-.29l.71-.71a1 1 0 1 0-1.41-1.41l-.66.71a1 1 0 0 0 0 1.41 1 1 0 0 0 .66.29Zm-12-.29a1 1 0 0 0 1.41 0 1 1 0 0 0 0-1.41l-.71-.71a1.004 1.004 0 1 0-1.43 1.41l.73.71ZM21 11h-1a1 1 0 0 0 0 2h1a1 1 0 0 0 0-2Zm-2.64 6A1 1 0 0 0 17 18.36l.71.71a1 1 0 0 0 1.41 0 1 1 0 0 0 0-1.41l-.76-.66ZM12 6.5a5.5 5.5 0 1 0 5.5 5.5A5.51 5.51 0 0 0 12 6.5Zm0 9a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7Zm0 3.5a1 1 0 0 0-1 1v1a1 1 0 0 0 2 0v-1a1 1 0 0 0-1-1Z" />
      </svg>
    </span>
    <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
        <path d="M21.64 13a1 1 0 0 0-1.05-.14 8.049 8.049 0 0 1-3.37.73 8.15 8.15 0 0 1-8.14-8.1 8.59 8.59 0 0 1 .25-2A1 1 0 0 0 8 2.36a10.14 10.14 0 1 0 14 11.69 1 1 0 0 0-.36-1.05Zm-9.5 6.69A8.14 8.14 0 0 1 7.08 5.22v.27a10.15 10.15 0 0 0 10.14 10.14 9.784 9.784 0 0 0 2.1-.22 8.11 8.11 0 0 1-7.18 4.32v-.04Z" />
      </svg>
    </span>
  </button>
</starlight-theme-toggle>

<script is:inline>
  (() => {
    const KEY = 'starlight-theme';
    const get = () => {
      try { return localStorage.getItem(KEY); } catch { return null; }
    };
    const set = (t) => {
      try { localStorage.setItem(KEY, t); } catch {}
    };
    const apply = (t) => {
      document.documentElement.dataset.theme = t;
    };
    const current = get() === 'light' ? 'light' : 'dark';
    set(current);
    apply(current);
  })();
</script>

<script>
  class StarlightThemeToggle extends HTMLElement {
    connectedCallback() {
      const btn = this.querySelector('button');
      if (!btn) return;
      const apply = (t: string) => {
        document.documentElement.dataset.theme = t;
        try { localStorage.setItem('starlight-theme', t); } catch {}
        this.dataset.theme = t;
        btn.setAttribute('aria-pressed', t === 'dark' ? 'true' : 'false');
        btn.setAttribute(
          'aria-label',
          t === 'dark' ? 'Switch to light theme' : 'Switch to dark theme',
        );
      };
      const initial = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
      apply(initial);
      btn.addEventListener('click', () => {
        const next = this.dataset.theme === 'dark' ? 'light' : 'dark';
        apply(next);
      });
    }
  }
  customElements.define('starlight-theme-toggle', StarlightThemeToggle);
</script>

<style>
  starlight-theme-toggle {
    display: inline-flex;
  }
  .theme-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    width: 4.2rem;
    height: 2rem;
    padding: 0.18rem;
    border: 1px solid var(--caracal-border-strong);
    border-radius: 6px;
    background: var(--caracal-panel-strong);
    color: var(--sl-color-text);
    cursor: pointer;
    box-shadow: 0 2px 8px color-mix(in srgb, black 16%, transparent);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      background 0.16s ease,
      color 0.16s ease,
      box-shadow 0.16s ease;
  }
  .theme-toggle::before {
    content: "";
    position: absolute;
    top: 0.18rem;
    left: 0.18rem;
    width: 1.62rem;
    height: 1.62rem;
    border-radius: 4px;
    background: #111827;
    box-shadow: 0 1px 3px color-mix(in srgb, black 22%, transparent);
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .theme-toggle:hover {
    transform: translateY(-1px);
    border-color: var(--caracal-link);
    box-shadow: 0 4px 12px color-mix(in srgb, black 18%, transparent);
  }
  .theme-toggle:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--caracal-link) 70%, transparent);
    outline-offset: 3px;
  }
  .theme-toggle__icon {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.62rem;
    height: 1.62rem;
    color: var(--caracal-text-subtle);
    transition: color 0.18s ease, opacity 0.18s ease;
  }
  .theme-toggle__icon svg {
    width: 0.94rem;
    height: 0.94rem;
    filter: none;
  }
  starlight-theme-toggle[data-theme='light'] .theme-toggle {
    border-color: #d8d0c3;
    background: #f3eee6;
  }
  starlight-theme-toggle[data-theme='dark'] .theme-toggle {
    border-color: #2a2f45;
    background: #0d1020;
  }
  starlight-theme-toggle[data-theme='dark'] .theme-toggle::before {
    transform: translateX(2.02rem);
    background: #f8ead1;
  }
  starlight-theme-toggle[data-theme='light'] .theme-toggle::before {
    background: #111827;
  }
  starlight-theme-toggle[data-theme='light'] .theme-toggle__icon--sun {
    color: #f8ead1;
  }
  starlight-theme-toggle[data-theme='dark'] .theme-toggle__icon--moon {
    color: #111827;
  }
  starlight-theme-toggle[data-theme='light'] .theme-toggle__icon--moon,
  starlight-theme-toggle[data-theme='dark'] .theme-toggle__icon--sun {
    color: #8b93a7;
  }
</style>
