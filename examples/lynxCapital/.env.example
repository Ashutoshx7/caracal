# Lynx Capital — multi-tenant Caracal reference environment
#
# Copy to .env and fill in. Values produced by `python scripts/provision.py` are
# written to config/provisioned.json (one-time secrets — keep both files untracked).
#
# Sections:
#   1. Deployment environment + Caracal service endpoints
#   2. Managed platform application (the durable runtime credential)
#   3. Control automation key (bootstraps provisioning)
#   4. Admin token (resource grants)
#   5. Domain resource upstreams (portfolio / research / compliance)
#   6. Model provider key
#   7. Optional: local mock provider swarm (legacy demo workload)

# 1. Deployment environment + Caracal service endpoints ------------------------
# One of: local | staging | production. Selects sane endpoint defaults and is
# echoed into provisioned object names so environments never collide.
CARACAL_ENVIRONMENT=local

# The zone is the isolation boundary that owns every application, resource, and
# policy below. One zone backs the whole Lynx Capital platform.
CARACAL_ZONE_ID=<placeholder-zone-id>

# Service endpoints. Local defaults shown; override per environment.
CARACAL_STS_URL=http://127.0.0.1:8080
CARACAL_COORDINATOR_URL=http://127.0.0.1:8085
CARACAL_GATEWAY_URL=http://127.0.0.1:8081
CARACAL_CONTROL_URL=http://127.0.0.1:8087
CARACAL_API_URL=http://127.0.0.1:8084

# 2. Managed platform application ----------------------------------------------
# The durable, managed registration the platform runtime authenticates as. Every
# tenant's agent sessions are spawned under this one application; per-tenant
# attribution comes from agent-session labels, not from extra applications.
CARACAL_APPLICATION_ID=<placeholder-managed-application-id>
CARACAL_APP_CLIENT_SECRET=<placeholder-managed-application-secret>

# 3. Control automation key ----------------------------------------------------
# A scoped control key used only by scripts/provision.py to author the managed
# app, resources, policy library, policy set, and per-tenant DCR applications.
CONTROL_CLIENT_ID=<placeholder-control-client-id>
CONTROL_CLIENT_SECRET=<placeholder-control-client-secret>
CONTROL_AUDIENCE=caracal-control

# 4. Admin token ---------------------------------------------------------------
# Resource grants are not part of the control catalog; provisioning binds each
# tenant's subject to its resource scopes through the Admin REST API.
CARACAL_ADMIN_TOKEN=<placeholder-admin-token>

# 5. Domain resource upstreams -------------------------------------------------
# The three services the platform protects. Identifiers and scopes live in
# config/tenancy.yaml; these point each identifier at its upstream per environment.
LYNX_RESOURCE_PORTFOLIO_URL=http://127.0.0.1:9500
LYNX_RESOURCE_RESEARCH_URL=http://127.0.0.1:9501
LYNX_RESOURCE_COMPLIANCE_URL=http://127.0.0.1:9502

# 6. Model provider key --------------------------------------------------------
OPENAI_API_KEY=sk-...

# 7. Optional: local mock provider swarm ---------------------------------------
# Only needed to run the bundled demo workload under _mock/. Unrelated to the
# multi-tenant identity model above.
# LYNX_PROVIDER_HEALTH_URL=http://127.0.0.1:9400/healthz
