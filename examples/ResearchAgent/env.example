# Caracal, a product of Garudex Labs
#
# Shell-compatible environment example for launching the ResearchAgent with caracal run.

# From examples/ResearchAgent, copy this file to .env, replace the Console
# values, then source it:
#   cp env.example .env
#   . .env
#   caracal run -- node agent.mjs
#
# This file does not authenticate by itself. Local dev/stable runs also require
# the one-time app client secret at:
#   ~/.config/caracal/runtime/$CARACAL_ZONE_ID/$CARACAL_APPLICATION_ID/client-secret
# and the resource mapping at:
#   ~/.config/caracal/runtime/$CARACAL_ZONE_ID/$CARACAL_APPLICATION_ID/credentials.json

# Do not put GOOGLE_DRIVE_ACCESS_TOKEN, GOOGLE_CALENDAR_ACCESS_TOKEN, or
# OPENAI_API_KEY in this file. Caracal injects those variables only into the
# launched agent process after STS authorizes the run.

export CARACAL_ZONE_ID="zone_prod"
export CARACAL_APPLICATION_ID="app_support_research_agent"
export CARACAL_RUN_TTL_SECONDS="900"
