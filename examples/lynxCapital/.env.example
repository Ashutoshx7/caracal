# Lynx Capital — workload environment (the running application)
#
# Copy to .env and fill in. These are the only Caracal variables the application reads at
# runtime. Provisioning the zone (creating the managed application, resources, and policy
# set) uses a separate operator file, .env.provision — never mix the two.
#
# Prefer a Console-generated runtime profile: download the application's caracal.toml from
# Console and point CARACAL_CONFIG at it. `Caracal.connect()` then resolves the zone,
# application credential, resources, and every service URL from that one file, so nothing
# below needs to be set by hand. The discrete variables are the fallback when you are not
# using a profile.

# --- Option A: Console runtime profile (preferred) ----------------------------
# Absolute or relative path to the caracal.toml profile Console generated for the managed
# application. When set, the discrete variables in Option B are not needed.
# CARACAL_CONFIG=./caracal.toml

# --- Option B: discrete workload credentials ----------------------------------
# The zone that owns the application, resources, and policy set.
CARACAL_ZONE_ID=<zone-id>

# The one durable managed application the platform runtime authenticates as. Every
# customer's agent sessions are spawned under this single application.
CARACAL_APPLICATION_ID=<managed-application-id>

# The managed application's client secret. Prefer the _FILE form so the secret is read from
# a file (for example a mounted Docker/Kubernetes secret) rather than the environment.
CARACAL_APP_CLIENT_SECRET=<managed-application-secret>
# CARACAL_APP_CLIENT_SECRET_FILE=/run/secrets/lynx_app_secret

# The resources this application may route to, as comma-separated slug=upstream pairs. The
# slugs match the resourceId values in config/tenancy.yaml.
CARACAL_RESOURCES=portfolio=http://127.0.0.1:9500,research=http://127.0.0.1:9501,compliance=http://127.0.0.1:9502

# --- Optional service overrides -----------------------------------------------
# Only set these when not using a profile and the services are not at their defaults; the
# SDK resolves them from the profile when one is present.
# CARACAL_STS_URL=http://127.0.0.1:8080
# CARACAL_GATEWAY_URL=http://127.0.0.1:8081
# CARACAL_COORDINATOR_URL=http://127.0.0.1:4000

# --- Application configuration -------------------------------------------------
# Model provider key for the agent runtime.
OPENAI_API_KEY=sk-...
